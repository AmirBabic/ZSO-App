<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#b32317">
    <title>{{title}} | ZSO-App</title>
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="stylesheet" href="/assets/app.css">
  </head>
  <body>
    <div class="offline-banner" data-offline-banner hidden>
      Offline: Online-Funktionen sind nicht verfügbar.
    </div>

    <header class="app-header">
      <a class="brand" href="/">ZSO-App</a>
      <span class="role">Rolle: {{currentRole}}</span>
    </header>

    <main class="page">
      {{{body}}}
    </main>

    <footer class="app-footer">
      <span>App {{version.appVersion}}</span>
      <span>Build {{version.buildTimestamp}}</span>
      <span>Commit {{version.commit}}</span>
    </footer>

    <script src="/assets/app.js" defer></script>
  </body>
</html>
